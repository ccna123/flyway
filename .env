# ── App ──────────────────────────────────────────────
APP_ENV=local          # local | prod  (shown in sidebar badge)
FLASK_DEBUG=false
SECRET_KEY=change-me-in-production
PORT=5000

# ── Database (Aurora PostgreSQL) ──────────────────────
DB_TYPE=postgresql
DB_HOST=my-cluster.cluster-xxxx.ap-northeast-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=mydb
DB_USER=flyway
DB_PASSWORD=supersecret
DB_SCHEMA=public

# ── Flyway / Docker ───────────────────────────────────
SQL_DIR=/tmp/flyway-sql
HOST_SQL_DIR=/host/path/to/sql  
FLYWAY_IMAGE=flyway/flyway:10-alpine
DOCKER_NETWORK=bridge
