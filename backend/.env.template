# ── App ──────────────────────────────────────────────
APP_ENV=local          # local | prod  (shown in sidebar badge)
FLASK_DEBUG=false
PORT=<PORT>

# ── AWS ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=<AWS_ACCESS_KEY_ID>
AWS_SECRET_ACCESS_KEY=<AWS_SECRET_ACCESS_KEY>
AWS_REGION=<AWS_REGION>

# ── Flyway / Docker ───────────────────────────────────
SQL_DIR=/tmp/flyway-sql
HOST_SQL_DIR=/host/path/to/sql   # HOST-side path for docker -v mount
FLYWAY_IMAGE=flyway/flyway:10-alpine
DOCKER_NETWORK=bridge
RELEASE=false
NGINX_USER=youruser
NGINX_PASS=yourpass
